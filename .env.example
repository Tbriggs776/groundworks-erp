# =====================================================================
# Groundworks ERP — environment variables
# Copy to `.env.local` for local dev. Never commit `.env.local`.
# =====================================================================

# ---------------------------------------------------------------------
# Supabase — same values in local AND production
# ---------------------------------------------------------------------
# From Supabase dashboard: Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the client. Bypasses RLS — used for
# privileged server work (background jobs, admin scripts). In Vercel,
# mark this variable as "Sensitive" so it's not visible in the UI.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ---------------------------------------------------------------------
# Database — Drizzle runtime client
# ---------------------------------------------------------------------
#
# IMPORTANT: which URL to use depends on the environment.
#
# LOCAL DEV:
#   Direct connection is fine (simpler, no pooler limits matter at scale 1):
#   postgresql://postgres:PASSWORD@db.YOUR-REF.supabase.co:5432/postgres
#
# PRODUCTION (Vercel, any serverless host):
#   MUST use the Supabase Transaction pooler URL. Serverless functions
#   open new DB connections per request and will exhaust the direct
#   connection pool fast. Get it from Supabase → Connect → Transaction pooler:
#   postgresql://postgres.YOUR-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# ON VERCEL WITH THE SUPABASE INTEGRATION:
#   You do NOT need to set DATABASE_URL. The integration auto-provisions
#   `POSTGRES_URL` (pooled) which our Drizzle client reads as a fallback.
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-REF.supabase.co:5432/postgres


# ---------------------------------------------------------------------
# Migrations — LOCAL ONLY, never set in Vercel
# ---------------------------------------------------------------------
# drizzle-kit and scripts/migrate.ts need a direct (session-mode) connection
# so they can take advisory locks. The pooler's transaction mode doesn't
# support those locks. Port 5432.
#
# Migrations run from your laptop, not from Vercel. Do NOT add this var to
# your Vercel project.
DATABASE_URL_MIGRATE=postgresql://postgres:PASSWORD@db.YOUR-REF.supabase.co:5432/postgres


# ---------------------------------------------------------------------
# App
# ---------------------------------------------------------------------
# The public URL the app is served from. Locally: http://localhost:3000
# On Vercel: https://your-project.vercel.app (or your custom domain).
NEXT_PUBLIC_APP_URL=http://localhost:3000
